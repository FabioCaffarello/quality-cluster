### ----------------------------------------------------------------------------
### Configctl smoke tests
### ----------------------------------------------------------------------------

@baseUrl = http://127.0.0.1:8080
@correlationId = test-http-configctl-001
# replace when create
@configId = 4aa70c859b5b5c813d9eabe2ef550569

### Create draft - JSON
POST {{baseUrl}}/configctl/configs
Content-Type: application/json
Accept: application/json
X-Correlation-ID: {{correlationId}}

{
  "name": "payments-prod",
  "format": "json",
  "content": "{\"config\":{\"name\":\"payments-prod\"},\"bindings\":{\"topics\":[\"billing.payment.created\"]}}"
}

###

### Create draft - YAML
POST {{baseUrl}}/configctl/configs
Content-Type: application/json
Accept: application/json
X-Correlation-ID: {{correlationId}}

{
  "name": "orders-prod",
  "format": "yaml",
  "content": "config:\n  name: orders-prod\nbindings:\n  topics:\n    - sales.order.created\n"
}

###

### Create draft - invalid payload
POST {{baseUrl}}/configctl/configs
Content-Type: application/json
Accept: application/json
X-Correlation-ID: {{correlationId}}

{
  "name": "",
  "format": "json",
  "content": ""
}

###

### List configs
GET {{baseUrl}}/configctl/configs
Accept: application/json
X-Correlation-ID: {{correlationId}}

###

### Get config by id
### Replace {{configId}} manually with an ID returned by create draft.
GET {{baseUrl}}/configctl/configs/by-id?id={{configId}}
Accept: application/json
X-Correlation-ID: {{correlationId}}

###

### Get config by id - missing id
GET {{baseUrl}}/configctl/configs/by-id
Accept: application/json
X-Correlation-ID: {{correlationId}}

###

### Get active config
GET {{baseUrl}}/configctl/configs/active
Accept: application/json
X-Correlation-ID: {{correlationId}}

###

### Validate draft - JSON valid
POST {{baseUrl}}/configctl/configs/validate
Content-Type: application/json
Accept: application/json
X-Correlation-ID: {{correlationId}}

{
  "format": "json",
  "content": "{\"config\":{\"name\":\"payments-prod\"}}"
}

###

### Validate draft - YAML valid
POST {{baseUrl}}/configctl/configs/validate
Content-Type: application/json
Accept: application/json
X-Correlation-ID: {{correlationId}}

{
  "format": "yaml",
  "content": "config:\n  name: payments-prod\n"
}

###

### Validate draft - invalid input
POST {{baseUrl}}/configctl/configs/validate
Content-Type: application/json
Accept: application/json
X-Correlation-ID: {{correlationId}}

{
  "format": "",
  "content": ""
}

###